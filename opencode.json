{
  "$schema": "https://opencode.ai/config.json",
  "mcp": {
  	"akshare-one-mcp": { "enabled": false },
  	"yahoo-finance-mcp": { "enabled": false },
    "ios-simulator": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "ios-simulator-mcp@^1.3.3"
      ],
      "enabled": true,
      "environment": {
        "IOS_SIMULATOR_MCP_DEFAULT_OUTPUT_DIR": "/tmp"
      }
    }
  }
}
